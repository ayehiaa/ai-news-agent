# Copy this file to .env and fill in your real values.
# NEVER commit .env to version control — it is excluded by .gitignore.

# Anthropic Claude API key — get from https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Gmail address used as the sender (must have 2FA enabled on the account)
GMAIL_SENDER=your-gmail@gmail.com

# Gmail App Password — NOT your main Gmail password.
# Steps to generate:
#   1. Enable 2-Step Verification at https://myaccount.google.com/security
#   2. Go to https://myaccount.google.com/apppasswords
#   3. App: Mail / Device: Other -> name it "AI News Agent"
#   4. Copy the 16-character code shown (it won't be shown again)
#   5. Paste it here without spaces, e.g.: abcdefghijklmnop
GMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# Recipient email address (set to same as GMAIL_SENDER for a self-digest)
RECIPIENT_EMAIL=ayehiaa@gmail.com
